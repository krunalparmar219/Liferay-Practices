<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.4.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_4_0.dtd">

<service-builder dependency-injector="ds" package-path="com.employee">

	<namespace>emp</namespace>
	<entity name="Employee" local-service="true" remote-service="true" uuid="true">

		<column name="employeeId" type="long" primary="true" />

		<column name="groupId" type="long" />
		<column name="companyId" type="long" />

		<column name="userId" type="long" />
		<column name="userName" type="String" />

		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<column name="employeeName" type="String" />
		<column name="email" type="String" />
		<column name="department" type="String" />
		<column name="salary" type="double" />

	</entity>
</service-builder>